{
  "name": "tarborist",
  "publisher": "tylermorganwall",
  "displayName": "tarborist",
  "description": "Static analysis for navigating and debugging complex R targets pipelines",
  "icon": "tarborist.png",
  "license": "GPL-3.0-or-later",
  "version": "0.7.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tylermorganwall/tarborist.git"
  },
  "private": true,
  "engines": {
    "positron": "^2026.03.0",
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:r",
    "onStartupFinished",
    "workspaceContains:_targets.R"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "configuration": {
      "title": "tarborist",
      "properties": {
        "tarborist.additionalSingleTargetFactories": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Additional `tar_target()`-like factory names to treat as single-target factories during static analysis. Use this only for factories that create exactly one target and follow the same `name` / `command` / `pattern` shape as `tar_target()`, for example `tar_parquet`."
        }
      }
    },
    "commands": [
      {
        "command": "tarborist.refreshIndex",
        "title": "tarborist: Refresh Pipeline Index"
      },
      {
        "command": "targetsTools.tarLoadHere",
        "title": "Targets: tar_load Here",
        "enablement": "isPositron && tarborist.canTarLoadHere"
      }
    ],
    "keybindings": [
      {
        "command": "targetsTools.tarLoadHere",
        "key": "ctrl+alt+shift+l",
        "mac": "cmd+alt+shift+l",
        "when": "editorTextFocus && editorLangId == r && isPositron && tarborist.canTarLoadHere"
      }
    ]
  },
  "scripts": {
    "test": "node --test test/unit/*.test.js"
  },
  "dependencies": {
    "@davisvaughan/tree-sitter-r": "^1.2.0",
    "@posit-dev/positron": "^0.2.0",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.7.1"
  }
}
